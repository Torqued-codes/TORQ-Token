{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": ["server/src/**/*.ts", "scripts/**/*.ts", "test/**/*.ts", "hardhat.config.ts"],
  "exclude": ["node_modules", "dist", "cache", "artifacts"]
}
